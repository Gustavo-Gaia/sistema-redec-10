{
  "manifest_version": 3,
  "name": "REDEC 10 - Sincronizador DETRAN",
  "version": "2.2",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.detran.rj.gov.br/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.detran.rj.gov.br/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
