{
  "manifest_version": 3,
  "name": "REDEC 10 - Sincronizador DETRAN",
  "version": "2.0",

  "permissions": ["storage"],

  "host_permissions": [
    "https://www.detran.rj.gov.br/*",
    "https://www2.detran.rj.gov.br/*",
    "https://sistema-redec-10.vercel.app/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.detran.rj.gov.br/*",
        "https://www2.detran.rj.gov.br/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
